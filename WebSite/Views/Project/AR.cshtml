            <div class="block"></div>
            <p>
                @Localizer[ProjectsResource.ArGalleryDesc]
            </p>
        </div>
        <div class="block"></div>
       
        <div class="row " style="display: flow-root;justify-content: center;object-fit:scale-down;">
           @*
            <div class="three columns "><img src="~/asset/img/Trivigno/1_res.png" class="image" onclick="openModal();currentSlide(1)" alt="Work Two" /></div>                    
            <div class="three columns "> <img src="~/asset/img/Trivigno/2.jpg" class="image" onclick="openModal();currentSlide(2)" alt="Work Three" /></div>
            <div class="three columns "> <img src="~/asset/img/Trivigno/3.jpg" class="image" onclick="openModal();currentSlide(3)" alt="Work Four" /></div>
            *@
