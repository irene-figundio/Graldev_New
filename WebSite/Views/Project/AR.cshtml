                </div>
            </div>
           
        </div>
        <div class="row " style="margin-top: 30px;">
          
            @*
            <div class="three columns "> <img src="~/asset/img/Trivigno/4.jpg" class="image" onclick="openModal();currentSlide(4)" alt="Work Five" /></div>
