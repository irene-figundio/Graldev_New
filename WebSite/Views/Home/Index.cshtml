        </button>
        <button class="w-10 h-10 lg:w-12 lg:h-12 border border-neon-green/30 flex items-center justify-center hover:bg-neon-green/10 transition-all text-neon-green" id="next-btn">
            <span class="material-symbols-outlined text-sm lg:text-base">arrow_forward_ios</span>
        </button>
    </div>
</section>

<section class="py-20 lg:py-32 px-6 lg:px-12 relative overflow-hidden">
