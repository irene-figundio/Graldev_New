<section class="py-20 lg:py-32 px-6 lg:px-12">
    <div class="container mx-auto">
        <div class="monitor-frame glass-terminal max-w-5xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="p-6 lg:p-10 border-b md:border-b-0 md:border-r border-neon-green/10">
                    <div class="data-point mb-6">@Localizer["ContactTag"]</div>
                    <h2 class="text-3xl lg:text-4xl font-display font-bold mb-8">@Localizer["ContactTitle"]</h2>
                    <form asp-controller="Home" asp-action="SendEmail" method="post" id="contactForm" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="font-mono text-[10px] lg:text-xs uppercase text-neon-green mb-2 block">@Localizer["FormOrg"]</label>
                            <input class="w-full bg-black/40 border border-neutral-700 font-mono text-sm p-3 focus:border-neon-green outline-none text-neon-green placeholder:text-neutral-700" placeholder="ROOT@COMPANY" type="text" name="orgName" />
                        </div>
                        <div>
                            <label class="font-mono text-[10px] lg:text-xs uppercase text-neon-green mb-2 block">@Localizer["FormEmail"]</label>
                            <input class="w-full bg-black/40 border border-neutral-700 font-mono text-sm p-3 focus:border-neon-green outline-none text-neon-green placeholder:text-neutral-700" placeholder="ADMIN@NETWORK" type="email" name="email" required />
                        </div>
                        <div>
                            <label class="font-mono text-[10px] lg:text-xs uppercase text-neon-green mb-2 block">@Localizer["FormPayload"]</label>
                            <textarea class="w-full bg-black/40 border border-neutral-700 font-mono text-sm p-3 focus:border-neon-green outline-none text-neon-green placeholder:text-neutral-700" placeholder="DESCRIBE INTEGRATION PARAMETERS..." rows="4" name="request" required></textarea>
                        </div>
                        <button type="submit" class="w-full border-2 border-neon-green py-4 font-mono font-bold text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">
                            @Localizer["FormSubmit"]
                        </button>
                    </form>
                    <div id="formResponse" class="mt-4 font-mono text-xs"></div>
                </div>
                <div class="relative bg-neutral-900 overflow-hidden min-h-[300px]">
                    <img alt="Map Visualization" class="w-full h-full object-cover opacity-30 grayscale sepia hue-rotate-[80deg] saturate-[2]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_tZHepD0uhzq_aVxslFV1ug16edQDuNaP4QhxBAyRONC8xOIL7HAYirlB71D5IqaUvJA8cIYfKIFDw7aOYxTMyCVKrOurVWS73UR7emTi1m29c6JEmubXWHEy0Ri-bQIIPRYMls5toG0BUfYr17iftEnOzk2_fdEeOC2IAXwCleJaK-bo5CiLWLxLI6rYQhskoA4TxGmRzyRLvg6hPNdDTKIak9Cf333ovIrpZBZDmWFgHwQAmrLmBEot0D1nGw7RUv-fmOeIQ84" />
                    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at center, transparent, #0a0a0c);"></div>
                    <div class="absolute bottom-6 left-6 border-l-2 border-neon-green pl-4 bg-charcoal/80 p-4 backdrop-blur-sm">
                        <div class="data-point">@Localizer["Geolocation"]</div>
                        <div class="font-mono text-xs lg:text-sm mt-1">@Localizer["HQ"]</div>
                        <div class="flex items-center gap-2 mt-3">
                            <span class="w-2 h-2 rounded-full bg-neon-green animate-ping"></span>
