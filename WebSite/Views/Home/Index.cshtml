        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('carousel-wrapper');
            const inner = document.getElementById('carousel-inner');
            const items = document.querySelectorAll('.carousel-item');
            const count = items.length;

            let rotation = 0;
            let isDragging = false;
            let startX = 0;
            let currentRotation = 0;
            let autoPlayInterval;

            function getRadius() {
                return window.innerWidth < 768 ? 200 : 380;
            }

            const getSpiralFactor = () => window.innerWidth < 768 ? 30 : 45;

            function updateCarousel() {
                const radius = getRadius();
                const spiralFactor = getSpiralFactor();

                items.forEach((item, i) => {
                    const angle = (i * (360 / count)) + rotation;
                    const rad = angle * (Math.PI / 180);

                    const x = Math.sin(rad) * radius;
                    const z = Math.cos(rad) * radius;
                    const y = Math.sin(rad) * spiralFactor;

                    const cardRotation = angle;
                    const normalizedZ = (z + radius) / (2 * radius);

                    const scale = 0.45 + (normalizedZ * 0.55);
                    const opacity = 0.15 + (normalizedZ * 0.85);
                    const blur = (1 - normalizedZ) * 6;

                    item.style.transform = `translate3d(${x}px, ${y}px, ${z}px) rotateY(${cardRotation}deg) scale(${scale})`;
                    item.style.opacity = opacity;
                    item.style.filter = `blur(${blur}px)`;
                    item.style.zIndex = Math.round(z + radius);

                    if (z > radius * 0.85) {
                        item.classList.add('active');
                        item.style.filter = 'blur(0px)';
                        item.style.opacity = '1';
                    } else {
                        item.classList.remove('active');
                    }
                });
            }

            function rotate(delta) {
                rotation += delta;
                updateCarousel();
            }

            container.addEventListener('mousedown', (e) => {
                isDragging = true;
                startX = e.clientX;
                currentRotation = rotation;
                clearInterval(autoPlayInterval);
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const deltaX = e.clientX - startX;
                rotation = currentRotation + (deltaX * 0.25);
                updateCarousel();
            });

            window.addEventListener('mouseup', () => {
                if (isDragging) {
                    isDragging = false;
                    startAutoPlay();
                }
            });

            container.addEventListener('touchstart', (e) => {
                isDragging = true;
                startX = e.touches[0].clientX;
                currentRotation = rotation;
                clearInterval(autoPlayInterval);
            });

            container.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const deltaX = e.touches[0].clientX - startX;
                rotation = currentRotation + (deltaX * 0.25);
                updateCarousel();
            });

            container.addEventListener('touchend', () => {
                isDragging = false;
                startAutoPlay();
            });

            document.getElementById('prev-btn').onclick = () => {
                clearInterval(autoPlayInterval);
                rotate(360/count);
                startAutoPlay();
            };
            document.getElementById('next-btn').onclick = () => {
                clearInterval(autoPlayInterval);
                rotate(-360/count);
                startAutoPlay();
            };

            window.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowLeft') rotate(15);
                if (e.key === 'ArrowRight') rotate(-15);
            });

            function startAutoPlay() {
                clearInterval(autoPlayInterval);
                autoPlayInterval = setInterval(() => {
                    rotate(-0.15);
                }, 30);
            }

            updateCarousel();
            startAutoPlay();

            let resizeTimer;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => {
                    updateCarousel();
                }, 200);
            });

            // AJAX Form Submission
            $('#contactForm').on('submit', function (e) {
                e.preventDefault();
                const form = $(this);
                const responseDiv = $('#formResponse');
                responseDiv.text('> SENDING_PAYLOAD...');

                // Combine orgName and request
                const orgName = form.find('input[name="orgName"]').val();
                const originalRequest = form.find('textarea[name="request"]').val();
                const combinedRequest = `Organization: ${orgName}\n\n${originalRequest}`;

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    headers: {
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    data: {
                        email: form.find('input[name="email"]').val(),
                        request: combinedRequest
                    },
                    success: function (response) {
                        if (response.success) {
                            responseDiv.addClass('text-neon-green').removeClass('text-red-500').text('> HANDSHAKE_COMPLETE: SUCCESS');
                            form[0].reset();
                        } else {
                            responseDiv.addClass('text-red-500').removeClass('text-neon-green').text('> ERROR: ' + response.message);
                        }
                    },
                    error: function () {
                        responseDiv.addClass('text-red-500').removeClass('text-neon-green').text('> SYSTEM_FAILURE: UNABLE_TO_REACH_ENDPOINT');
                    }
                });
            });
        });
    </script>
}
