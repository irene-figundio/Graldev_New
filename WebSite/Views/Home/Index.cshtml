@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}

<section class="relative min-h-[90vh] lg:min-h-screen flex items-center px-6 lg:px-12 overflow-hidden border-b border-neon-green/10">
    <div class="absolute right-[-20%] lg:right-[-10%] top-1/2 -translate-y-1/2 w-full lg:w-2/3 h-[60%] lg:h-[80%] opacity-30 lg:opacity-40 pointer-events-none">
        <img alt="Digital Blueprint Wireframe" class="w-full h-full object-contain mix-blend-screen grayscale contrast-150 brightness-75" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDux_tq-j7grrdes9ZWlRZO7js_HTW7y_7qnbalJa5sAqIiSWQJBWMSX4_HDHjfa5rReEyHBlG1yI0D3mcP0_FRtvl9DLzLCVaFeGOO7_nktJ5727BLZKIhPy3F_pK5l-CEiOcxoCCuOF1u8gaPpvquD7AvArdaXo_qmFLSqzLxPniH7lhhctM6TNmSXrfhUR_fdlqWnwgBLpWVg7fkCt2atgOpgmFJ_OTvHn5q8ib8tP6YReVWFc4XxxEp_OEl19e5yRJopXBToNQ" style="filter: sepia(100%) saturate(1000%) hue-rotate(80deg);" />
    </div>
    <div class="container mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="monitor-frame glass-terminal p-6 lg:p-10">
            <div class="flex items-center gap-4 mb-6 lg:mb-8 border-b border-neon-green/20 pb-4">
                <div class="flex gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-green-500/50"></div>
                </div>
                <div class="data-point">SYS_ARCH // BOOT_SEQ: SUCCESS</div>
            </div>
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-black leading-none mb-6 tracking-tighter">
                GRAL<span class="text-neon-green green-text-glow">DEV</span><br />
                <span class="text-xl lg:text-2xl font-mono block mt-2 text-neutral-400">@Localizer["HeroSubtitle"]</span>
            </h1>
            <p class="font-mono text-sm lg:text-lg text-neon-green/80 mb-8 lg:mb-10 max-w-xl leading-relaxed">
                @Localizer["HeroLine1"]<br />
                @Localizer["HeroLine2"]<br />
                @Localizer["HeroLine3"]
            </p>
            <div class="flex flex-wrap gap-4">
                <button class="flex-1 lg:flex-none bg-neon-green text-charcoal px-6 lg:px-8 py-4 font-mono font-bold hover:bg-white hover:shadow-[0_0_30px_rgba(255,255,255,0.3)] transition-all text-sm lg:text-base">
                    @Localizer["HeroButton1"]
                </button>
                <button class="flex-1 lg:flex-none border border-neon-green text-neon-green px-6 lg:px-8 py-4 font-mono hover:bg-neon-green/10 transition-all text-sm lg:text-base">
                    @Localizer["HeroButton2"]
                </button>
            </div>
            <div class="mt-10 lg:mt-12 flex justify-between items-end">
                <div class="space-y-1">
                    <div class="data-point">LATENCY: 12ms</div>
                    <div class="data-point">UPTIME: 99.999%</div>
                </div>
                <div class="w-24 lg:w-32 h-1 bg-neon-green/20 relative">
                    <div class="absolute top-0 left-0 h-full w-2/3 bg-neon-green animate-pulse"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3D SPIRAL SERVICES CAROUSEL -->
<section class="py-20 lg:py-32 px-4 lg:px-12 relative overflow-hidden bg-black/20" id="services-carousel-section">
    <div class="absolute inset-0 spiral-bg pointer-events-none"></div>
    <div class="container mx-auto relative z-10 text-center mb-12 lg:mb-16">
        <div class="data-point mb-4 border-b border-neon-green/30 inline-block px-4 pb-1">@Localizer["ServicesTag"]</div>
        <h2 class="text-3xl md:text-5xl lg:text-6xl font-display font-black tracking-tighter uppercase mb-2">@Localizer["ServicesTitle"]</h2>
        <p class="font-mono text-[10px] text-neutral-500 uppercase tracking-widest">@Localizer["CarouselHint"]</p>
    </div>
    <div class="relative h-[450px] lg:h-[550px] w-full max-w-5xl mx-auto carousel-container select-none" id="carousel-wrapper">
        <div class="carousel-inner w-full h-full relative" id="carousel-inner">
            <div class="carousel-item group" data-index="0">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">cloud_done</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">Nexus_Cloud</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Adaptive infrastructure scaling with sub-millisecond propagation latency.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
            <div class="carousel-item group" data-index="1">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">security</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">Vault_Secure</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Hardware-isolated encryption modules for sensitive enterprise data assets.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
            <div class="carousel-item group" data-index="2">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">insights</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">Data_Vision</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Predictive modeling utilizing deep-layer recursive neural networks.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
            <div class="carousel-item group" data-index="3">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">settings_input_component</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">API_Flow</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Universal connector protocols for legacy-to-future integration chains.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
            <div class="carousel-item group" data-index="4">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">satellite_alt</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">Edge_Sync</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Globally distributed computation nodes for optimized user experience.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
            <div class="carousel-item group" data-index="5">
                <div class="glass-card">
                    <span class="material-symbols-outlined text-4xl lg:text-5xl text-neon-green mb-4 lg:mb-6 group-hover:scale-125 transition-transform duration-500">stream</span>
                    <h3 class="font-mono text-lg lg:text-xl font-bold mb-2 lg:mb-4 text-white uppercase">Pulse_Stream</h3>
                    <p class="text-neutral-400 text-xs lg:text-sm font-mono leading-relaxed mb-6 lg:mb-8">Real-time telemetry and monitoring with automated failure recovery.</p>
                    <button class="mt-auto border border-neon-green/40 px-6 py-2 text-[10px] font-mono text-neon-green hover:bg-neon-green hover:text-charcoal transition-all">@Localizer["ViewDetails"]</button>
                </div>
            </div>
        </div>
    </div>
    <div class="flex justify-center gap-4 mt-4 lg:mt-8">
        <button class="w-10 h-10 lg:w-12 lg:h-12 border border-neon-green/30 flex items-center justify-center hover:bg-neon-green/10 transition-all text-neon-green" id="prev-btn">
