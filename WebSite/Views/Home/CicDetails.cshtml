@using WebSite.Resources
@using WebSite.Model
@using Microsoft.AspNetCore.Mvc.Localization

@inject IViewLocalizer Localizer

@inject IOptions<AppInfo> AppInfo
@inject IOptions<ContactsInfo> ContactsInfo
@inject IOptions<MailSettings> MailSettings

@{
    ViewData["Title"] = "ConsulenzeInCloud";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* message modals *@
<!-- Success Modal -->
<!-- Frame Modal Top Info-->
<div class="modal fade " id="success-box" tabindex="-1" role="dialog" aria-labelledby="successModalLabel" aria-hidden="true" data-backdrop="false">
    <div class="modal-dialog  modal-dialog-centered" role="document">
        <!--Content-->
        <div class="modal-content" style="background: linear-gradient(to bottom left,#B0DB7D 40%, #99DBB4 100%); border-radius: 20px; box-shadow: 5px 5px 20px rgba(#CBCDD3, 10%);">
            <!--Body-->
            <div class="modal-body">
                <div class="row d-flex justify-content-center align-items-center">
                    <p class="pt-3 pr-2" style="text-align: center; text-transform: uppercase; font-family: monospace; font-weight: bold;color:white;">
                        <strong> <i class="fa-solid fa-face-smile-beam fa-bounce fa-2xl" style="color: #f5f5f5;"></i>  </strong><br />
                        @Localizer[Message.SendSuccess]
                    </p>
                    <button id="closeSuccessModal" role="button" class="btn original-button-Success" data-dismiss="modal"> @Localizer[Message.OK]</button>
                </div>
            </div>
        </div>
        <!--/.Content-->
    </div>
</div>

<!-- Error Modal -->
<!-- Frame Modal Top Info-->
<div class="modal fade " id="error-box" tabindex="-1" role="dialog" aria-labelledby="errorModalLabel" aria-hidden="true" data-backdrop="false">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <!--Content-->
        <div class="modal-content" style="background: linear-gradient(to bottom left, #EF8D9C 40%, #FFC39E 100%);
  border-radius: 20px;
  box-shadow: 5px 5px 20px rgba(#CBCDD3, 10%);">
            <!--Body-->
            <div class="modal-body">
                <div class="row d-flex justify-content-center align-items-center">
                    <div class="pt-3 pr-2" style="text-align: center; text-transform: uppercase; font-family: monospace; font-weight: bold;color:white;">
                        <strong> <i class="fa-solid fa-face-frown-open fa-bounce fa-2xl move" style="color:white;"></i> </strong><br />
                        <div id="modalMessage">
                            @Localizer[Message.SomeWrong]
                        </div>
                    </div>
                    <button id="closeErrorModal" role="button" class="btn original-button" data-dismiss="modal">
                        @Localizer[Message.riprova]
                    </button>
                </div>

            </div>
        </div>
        <!--/.Content-->
    </div>
</div>



<div class="home" style="display: flex; justify-content: center;" id="topLanding">
    <video preload="metadata" poster="~/asset/img/backgroundCIC.png" id="videoDesktop" muted loop autoplay playsinline>
        <source src="~/asset/video/CIC.mp4" type="video/mp4" />
    </video>
    <video preload="metadata" poster="~/asset/img/backgroundCIC.png" id="videoMobile" muted loop autoplay playsinline style="display:none;">
        <source src="~/asset/video/CIC.mp4" type="video/mp4" />
    </video>

    <div class="title" style=" text-align: center;">
        <p class="heading">
            <h1 class="reveal">Consulenze
                <span >in Cloud<sup>TM</sup></span>
            </h1>
            <br />
            <br />
        </p>
        <a href="#cic_about">
            <div class="scrolling2 hidden-sm-up">
                <div class="mouse2">

                    <div class="wheel"></div>
                </div>
                <div>
                    <span class="unu center"></span>
                    <span class="doi center"></span>
                </div>
            </div>
        </a>
    </div>

</div>

<section id="spaceBar" style="background: #f9f6f6fa;">
    <br />
</section>

<div class="background cic-two parallax">
    <h1>@Localizer[ClientsResource.CIC_About]</h1>
</div>
<!-- Intro Section
–––––––––––––––––––––––––––––––––––––––––––––––––– -->
<section id="cic_about" style="background:#ffffff; padding: 60px 0;">
    <div class="container">
        <div class="row d-flex align-items-center" style="flex-wrap: wrap;">

            <!-- Colonna testo -->
            <div class="col-md-12">
                <h2 style="font-weight: bold; text-transform: uppercase;">Cos’è Consulenze in Cloud<sup>TM</sup>?</h2>
                <p>Consulenze in Cloud<sup>TM</sup> è la piattaforma integrata per la gestione documentale e l’interazione digitale tra aziende, consulenti, enti pubblici ed enti di certificazione, utilizzabile dove vuoi e su ogni tuo device.</p>
                <p>Consulenze in Cloud nasce dall’intuizione di due professionisti lucani che uniscono competenze in soluzioni IT/ICT, accreditamento istituzionale e certificazioni ISO. </p>
                <h4 style="font-weight: bold; text-transform: uppercase;">Punti chiave</h4>
                <ul>
                    <li><strong>Digitalizzazione completa del processo;</strong></li>
                    <li><strong>Tracciabilità e controllo centralizzato;</strong></li>
                    <li><strong>Conformità alle normative (es. ISO, accreditamento regionale);</strong></li>
                    <li><strong>Fruibilità via browser e dispositivi mobili;</strong> </li>
                    <li><strong>Modularità multi-utenza, multi-cliente, multi-regione e multi-norma.</strong></li>
                </ul>
               
                <p>Vuoi saperne di più?</p>
                <a href="#ContactDesktop" class="btn btn-primary mt-3">Contattaci</a>
            </div>
        </div>
    </div>
</section>
<!-- Why Section
–––––––––––––––––––––––––––––––––––––––––––––––––– -->
<section id="spaceBar" style="background: #f9f6f6fa;">
    <br />
</section>

<div class="background cic-one parallax">
    <h1>@Localizer[ClientsResource.Functionality]</h1>
</div>

<section id="cic_functionality" style="background:#ffffff; padding: 60px 0;">
    <div class="container">
        <div class="row d-flex align-items-center" style="flex-wrap: wrap;">
            <!-- Colonna testo -->
            <div class="col-md-12">
                <h2 style="font-weight: bold; text-transform: uppercase;">Funzionalità</h2>
                <ul>
                    <li>
                        Automazione dei processi di audit;

                    </li>
                    <li>
                        Comunicazione digitalizzata tra soggetti istituzionali e privati;
                    </li>
                    <li>
                        Ottimizzazione dei flussi di comunicazione tra aziende, consulenti ed enti di certificazione ISO, enti di accreditamento o altri, pubblici o privati;
                    </li>
                    <li>
                        Automazione dell’intero ciclo documentale – archiviazione, condivisione, analisi e audit – per soddisfare i requisiti delle normative ISO e dell’accreditamento istituzionale;
                    </li>
                    <li>
                        Gestione centralizzata e tracciabile dell’intero iter di accreditamento o di certificazione ISO;
                    </li>
                </ul>
                <p><strong>Vantaggi:</strong></p>
                <ul>
                    <li>Pronto all’uso</li>
                    <li>Riduzione di tempi e costi di gestione</li>
                    <li>Maggiore conformità normativa e sicurezza</li>
                    <li>Interfaccia intuitiva e user-friendly</li>
                </ul>
                <p>Vuoi saperne di più?</p>
                <a href="#ContactDesktop" class="btn btn-primary mt-3">Contattaci</a>
            </div>
        </div>
    </div>

<!-- Why Section
–––––––––––––––––––––––––––––––––––––––––––––––––– -->
<section id="spaceBar" style="background: #f9f6f6fa;">
    <br />
</section>

<div class="background cic-one parallax">
    <h1>@Localizer[ClientsResource.CIC_Why]</h1>
</div>
<section id="cic_why" style="background:#ffffff; padding: 60px 0;">
    <div class="container">
        <div class="row d-flex align-items-center" style="flex-wrap: wrap;">
            <!-- Colonna testo -->
            <div class="col-md-12">
                <h2 style="font-weight: bold; text-transform: uppercase;">pERCHè SCEGLIERE Consulenze in Cloud<sup>TM</sup>?</h2>
                <ul>
                    <li><strong>Primo sistema SaaS</strong> completo per il dialogo normativo tra aziende ed enti;</li>
                    <li><strong>Architettura a 3 livelli</strong>: Aziende/Consulenti, Enti/Regioni/OTA, Team di audit;</li>
                    <li><strong>Digitalizzazione</strong> completa del processo di audit;</li>
                    <li><strong>Flussi documentali personalizzabili</strong> per normativa, regione e anno;</li>
                    <li><strong>Soluzione scalabile</strong> per centinaia di clienti su un’unica piattaforma;</li>
                    <li><strong>Pannello di controllo centralizzato</strong> per ogni fase del processo.</li>
                </ul>
                <p>Vuoi saperne di più?</p>
                <a href="#ContactDesktop" class="btn btn-primary mt-3">Contattaci</a>
            </div>

        </div>
    </div>
</section>
<div class="bkgmobile" style="display:none;width:100%">
    <img class="Imgbkgmobile" src="~/asset/img/ContactUs.jpg" />
</div>

<div class="background four parallax">
    <h1>@Localizer[MainResource.ContactUs]</h1>
</div>
<!-- Contact Section
–––––––––––––––––––––––––––––––––––––––––––––––––– -->
<section id="spaceBar" style="background: #f9f6f6fa;">
    <br />
</section>
<section id="ContactDesktop" style="background: #f9f6f6fa;">

    <br />
    <div class="container" style="display:flex;justify-content: center;flex-direction: row-reverse;">
        <div class="block"></div>
        <div style="border: 3px solid #607D8B;margin-left: 51px;">
            <div class="map-responsive">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3027.4957946249706!2d15.834202912298624!3d40.641000141838866!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1338e31862b2b7fb%3A0xf29e8cdc71b253fd!2sGraldev%20S.a.s.%20di%20Omar%20Marino!5e0!3m2!1sit!2sit!4v1695903543919!5m2!1sit!2sit" width="300" height="520" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
        <div class="row">
            <div class="w3-large w3-margin-bottom">
                <i class="fa fa-map-marker w3-hover-text-black" style="width:30px"></i>@ContactsInfo.Value.Address - @ContactsInfo.Value.Cap - @ContactsInfo.Value.City <br>
                <i class="fa fa-phone w3-hover-text-black" style="width:30px"></i> Phone: @ContactsInfo.Value.Telefono<br>
                <i class="fa fa-envelope w3-hover-text-black" style="width:30px"> </i> Email: @ContactsInfo.Value.Email<br>
            </div>

            @* Contact Form *@
            <form asp-controller="Home" asp-action="SendEmail" method="post" onsubmit="showContactModal()">
                <div class="row">
                    <div class="six columns">
                        <label for="email" style="margin-top: 11px;"> Email</label>
                    </div>
                    <input class="u-full-width" name="email" style=" border: 1px solid #bfd3dd;box-shadow: 1px 1px 5px 0px #9E9E9E;" type="email">
                </div>
                <div class="row">
                    <div class="six columns">
                        <label for="request">Message</label>
                    </div>
                    <textarea name="request" class="u-full-width lblbox"></textarea>
                    <input id="submit-button" class="btn-primary" type="submit" value="Submit">
                </div>
            </form>

        </div>

    </div>
    <br />
</section>
<section id="spaceBar" style="background: #f9f6f6fa;">
    <br />
</section>

<section id="ContactMobile" style="background: #f9f6f6fa;display:none;">

    <div class="container" style="display: flex;flex-direction: column;flex-wrap: nowrap;align-content: center;justify-content: space-evenly;align-items: center;">
        <h1 style="font-weight: 600;text-transform: uppercase;">@Localizer[MainResource.ContactUs]</h1>
        <div class="block"></div>
        <form asp-controller="Home" asp-action="SendEmail" method="post" onsubmit="showContactModal()">
            <div class="row">
                <div class="six columns">
                    <label for="email" style="margin-top: 11px;">Email</label>
                </div>
                <input class="u-full-width" name="email" style=" border: 1px solid #bfd3dd;box-shadow: 1px 1px 5px 0px #9E9E9E;" type="email">
            </div>
            <div class="row">
                <div class="six columns">
                    <label for="request">Message</label>
                </div>
                <textarea class="u-full-width" name="request" style=" border: 1px solid #bfd3dd;box-shadow: 1px 1px 5px 0px #9E9E9E;"></textarea>
                <input id="submit-button" class="btn-primary" type="submit" value="Submit">
            </div>
        </form>

        <br />
        <div class="row">
            <div class="w3-large w3-margin-bottom">
                <i class="fa fa-map-marker w3-hover-text-black" style="width:30px"></i>@ContactsInfo.Value.Address - @ContactsInfo.Value.Cap - @ContactsInfo.Value.City <br>
                <i class="fa fa-phone w3-hover-text-black" style="width:30px"></i> Phone: @ContactsInfo.Value.Telefono<br>
                <i class="fa fa-envelope w3-hover-text-black" style="width:30px"> </i> Email: @ContactsInfo.Value.Email<br>
            </div>
        </div>
        <br />
        <div class="row" style="border: 3px solid #607D8B;">
            <div class="map-responsive">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3027.4957946249706!2d15.834202912298624!3d40.641000141838866!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1338e31862b2b7fb%3A0xf29e8cdc71b253fd!2sGraldev%20S.a.s.%20di%20Omar%20Marino!5e0!3m2!1sit!2sit!4v1695903543919!5m2!1sit!2sit" width="300" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>

    <br />
</section>
<section id="spaceBar" style="background: #f9f6f6fa;">
</section>


<!-- Modals Section
–––––––––––––––––––––––––––––––––––––––––––––––––– -->
<!-- Supporto e Consulenza IT - TLC  -->
<div class="modal fade" id="tlc-modal" tabindex="-1" role="dialog" aria-labelledby="tlcModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Html.Raw(ClientsResource.TlcclientTitle)</h5>
            </div>
            <div class="modal-body">
                <div class="container-fluid">
                    <div class="row">
                        <!-- Image on top -->
                        <img id="modalInfoImage" src="" class="img-fluid" alt="Image">
                    </div>
                    <div class="row">
                        <!-- Text on bottom -->
                        <br />
                        <div style="font-family: Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #333;">
                            <br />
                            @Html.Raw(ClientsResource.SupportModal)
                            @* icon list :
                            <i class="fa-solid fa-headset"style="color: #37d28a;" ></i>
                            *@
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="modal-btn btn btn-primary">@Localizer[Message.Contattaci]</button>
            </div>
        </div>
    </div>
</div>

