        $(document).ready(function () {       
            
            $('form').submit(function (e) {
                e.preventDefault(); // Prevent form submission
                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (response) {
                        if (response.success) {
                            $('#success-box').modal('show');
                            $('form')[0].reset(); // Reset form fields
                            $('#closeSuccessModal').click(function () {
                                $('#success-box').modal('hide');
                            });
                        } else {
                           // $('#error-box').find('.modal-body').text(response.message);
                            $('#error-box').find('#modalMessage').text(response.message);
                            $('#error-box').modal('show');
                            $('#closeErrorModal').click(function () {
                                $('#error-box').modal('hide');
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        // Handle AJAX error
                        console.error(xhr.responseText);
                    }
                });
            });
