        function goToTop() {
            // Get the position of the target section
            document.body.scrollTop = 0; // For Safari
            document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE, and Opera
        }
        // Show or hide the button based on scroll position
        window.onscroll = function () { scrollFunction() };

        function scrollFunction() {
            if (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20) {
                document.getElementById("goToTopBtn").style.display = "block";
            } else {
                document.getElementById("goToTopBtn").style.display = "none";
            }
        }


        function handleCookiesBanner() {
            const cookiesBanner = $(".cookies-banner-container");
            const acceptedCookies = getCookie("accepted_cookies");
            const policyUrl = "@urlPolicy";
            const policyText = "Term and Privacy Policy";

            if (!acceptedCookies) {
                const acceptBtn = cookiesBanner.find(".cookies-banner__accept-btn button");
                acceptBtn.on("click", function () {
                    setCookie("accepted_cookies", "true", 20);
                    cookiesBanner
                        .css("transform", "translateY(100%)")
                        .one("transitionend", function () {
                            $(this).remove();
                        });
                });
                cookiesBanner.show();

                const cookiesPolicyLink = $(".cookies-banner__terms-and-policy");
                cookiesPolicyLink.attr("href", policyUrl);
                cookiesPolicyLink.text(policyText);
            } else {
                cookiesBanner.remove();
            }
            function setCookie(name, value, days) {
                let expires = "";
                if (days) {
                    const date = new Date();
                    date.setTime(date.getTime() + days * 24 * 60 * 60 * 1000);
                    expires = "; expires=" + date.toUTCString();
                }

                document.cookie = name + "=" + (value || "") + expires + "; path=/";
            }

            function getCookie(name) {
                const cookieValue = document.cookie.match(
                    "(^|;)\\s*" + name + "\\s*=\\s*([^;]+)"
                );
                return cookieValue ? cookieValue.pop() : null;
            }
        }
        $(handleCookiesBanner);
       
